rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isActive() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Ads collection
    match /ads/{adId} {
      allow read: if true;
      allow create: if isActive();
      allow update: if isActive() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if resource.data.userId == request.auth.uid || isAdmin();
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Favorites collection
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated();
      allow create: if isActive() && request.resource.data.userId == request.auth.uid;
      allow delete: if resource.data.userId == request.auth.uid;
    }

    // Chats collection
    match /chats/{chatId} {
      allow read: if isAuthenticated() && 
        (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow create: if isActive();
      allow update: if isAuthenticated() &&
        (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          (get(/databases/$(database)/documents/chats/$(chatId)).data.buyerId == request.auth.uid ||
           get(/databases/$(database)/documents/chats/$(chatId)).data.sellerId == request.auth.uid);
        allow create: if isActive() && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated();
        allow delete: if false;
      }
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Reports collection
    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isActive();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Banners collection
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Featured ads collection
    match /featured_ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Cities collection
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Governorates collection
    match /governorates/{governorateId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
